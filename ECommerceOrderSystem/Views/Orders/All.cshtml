@model IReadOnlyList<ECommerceOrderSystem.Models.ViewModels.Orders.OrderListItemViewModel>
@{
    ViewData["Title"] = "All Orders";
}
<div class="mb-4"><span class="text-primary fw-semibold small">ADMIN</span><h1 class="display-6 fw-bold">All orders</h1><p class="text-muted">Review purchases and monitor order fulfilment.</p></div>
<div class="row g-3 mb-4"><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Total orders</span><div class="h3 fw-bold mt-1">@Model.Count</div></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Awaiting action</span><div class="h3 fw-bold mt-1">@Model.Count(order => order.Status is OrderStatus.Pending or OrderStatus.Paid)</div></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Revenue</span><div class="h3 fw-bold mt-1">@Model.Sum(order => order.GrandTotal).ToString("N2") LKR</div></div></div></div></div>
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="p-3">Order</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach(var order in Model)
                {
                    <tr>
                        <td class="p-3 fw-bold">@order.OrderNumber</td>
                        <td>@order.CustomerName</td>
                        <td>@order.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@order.ItemCount</td>
                        <td class="fw-semibold">@order.GrandTotal.ToString("N2") LKR</td>
                        <td>
                            <span class="text-bg-primary">@order.Status</span>
                        </td>
                        <td class="text-end pe-3">
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
