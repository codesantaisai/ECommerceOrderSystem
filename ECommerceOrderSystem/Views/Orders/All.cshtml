@{ ViewData["Title"] = "All Orders"; }
<div class="mb-4"><span class="text-primary fw-semibold small">ADMIN</span><h1 class="display-6 fw-bold">All orders</h1><p class="text-muted">Review purchases and monitor order fulfilment.</p></div>
<div class="row g-3 mb-4"><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Total orders</span><div class="h3 fw-bold mt-1">128</div></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Awaiting action</span><div class="h3 fw-bold mt-1">14</div></div></div></div><div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><span class="text-muted">Revenue</span><div class="h3 fw-bold mt-1">$24,850</div></div></div></div></div>
<div class="card border-0 shadow-sm"><div class="card-header bg-white p-3"><div class="row g-2"><div class="col-md-8"><input class="form-control" placeholder="Search by order or customer..." /></div><div class="col-md-4"><select class="form-select"><option>All statuses</option><option>Pending</option><option>Paid</option><option>Shipped</option><option>Delivered</option></select></div></div></div><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th class="p-3">Order</th><th>Customer</th><th>Date</th><th>Total</th><th>Status</th><th></th></tr></thead><tbody>
@foreach (var row in new[] { new { Id="1", Order="ORD-1048", Customer="Alex Morgan", Date="10 Jul 2026", Total="$378.50", Status="Paid", Badge="primary" }, new { Id="2", Order="ORD-1047", Customer="Jamie Chen", Date="09 Jul 2026", Total="$79.00", Status="Pending", Badge="warning" }, new { Id="3", Order="ORD-1046", Customer="Sam Wilson", Date="09 Jul 2026", Total="$249.00", Status="Shipped", Badge="info" } }) { <tr><td class="p-3 fw-bold">@row.Order</td><td>@row.Customer</td><td>@row.Date</td><td class="fw-semibold">@row.Total</td><td><span class="badge text-bg-@row.Badge">@row.Status</span></td><td class="text-end pe-3"><a asp-action="Details" asp-route-id="@row.Id" class="btn btn-sm btn-outline-dark">View</a></td></tr> }
</tbody></table></div></div>
