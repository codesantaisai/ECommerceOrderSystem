@{ ViewData["Title"] = "Create Order"; }
<div class="mb-4"><span class="text-primary fw-semibold small">NEW ORDER</span><h1 class="display-6 fw-bold">Create order</h1><p class="text-muted">Select products and review your order before placing it.</p></div>
<div class="row g-4"><div class="col-lg-8"><div class="card border-0 shadow-sm"><div class="card-header bg-white p-4"><h2 class="h5 fw-bold mb-1">Available products</h2><p class="text-muted small mb-0">Choose quantities for the products you need.</p></div><div class="list-group list-group-flush">
@foreach (var item in new[] { new { Name="Wireless Headphones", Price="249.00", Stock="18 available" }, new { Name="Mechanical Keyboard", Price="129.50", Stock="7 available" }, new { Name="Ergonomic Mouse", Price="79.00", Stock="32 available" } }) { <div class="list-group-item p-4 d-flex justify-content-between align-items-center"><div><strong>@item.Name</strong><div class="text-muted small">$@item.Price · @item.Stock</div></div><div class="input-group" style="width:130px"><button type="button" class="btn btn-outline-secondary">−</button><input class="form-control text-center" value="0" /><button type="button" class="btn btn-outline-secondary">+</button></div></div> }
</div></div></div><div class="col-lg-4"><div class="card border-0 shadow-sm sticky-top" style="top:1rem"><div class="card-body p-4"><h2 class="h5 fw-bold">Order summary</h2><div class="d-flex justify-content-between py-3 border-bottom"><span class="text-muted">Items</span><strong>0</strong></div><div class="d-flex justify-content-between py-3"><span class="h5">Total</span><strong class="h4">$0.00</strong></div><label class="form-label fw-semibold">Shipping address</label><textarea class="form-control" rows="4" placeholder="Street, city and postal code"></textarea><button type="button" class="btn btn-primary btn-lg w-100 mt-4">Place Order</button></div></div></div></div>
