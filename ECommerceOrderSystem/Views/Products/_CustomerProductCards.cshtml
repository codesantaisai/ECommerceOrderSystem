@model IReadOnlyList<Product>
<div class="row g-4">
    @foreach(var item in Model)
    {
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:180px">
                    <span class="display-2 fw-bold text-primary">@item.Name[0]</span>
                </div><div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between gap-2">
                        <h2 class="h5 fw-bold">@item.Name</h2>
                        <strong class="text-nowrap">LKR @item.Price.ToString("N2")</strong>
                    </div>
                    <p class="text-muted small flex-grow-1">@item.Description</p>
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <span class="badge  @(item.Stock == 0 ? "text-danger" : "text-success")">@(item.Stock == 0 ? "Out of stock" : $"{item.Stock} in stock")</span>
                        @if(User.Identity?.IsAuthenticated == true && User.IsInRole("CUSTOMER") && item.Stock > 0)
                        {
                            <a asp-controller="Orders" asp-action="Create" asp-route-productId="@item.Id" class="btn btn-primary btn-sm">Order Now</a>
                        }
                        else if(User.Identity?.IsAuthenticated != true && item.Stock > 0)
                        {

                            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("Create", "Orders", new { productId = item.Id })" class="btn btn-outline-primary btn-sm">Login to Order</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
