@{ var editing = Context.Request.Path.Value?.Contains("Edit", StringComparison.OrdinalIgnoreCase) == true; ViewData["Title"] = editing ? "Edit Product" : "Create Product"; }
<div class="row justify-content-center py-4"><div class="col-lg-8">
    <a asp-action="Index" class="text-decoration-none">← Back to products</a>
    <div class="mt-3 mb-4"><span class="text-primary fw-semibold small">ADMIN</span><h1 class="display-6 fw-bold">@(editing ? "Edit product" : "Create product")</h1><p class="text-muted">@(editing ? "Update the product information and inventory." : "Add a new product to the store catalog.")</p></div>
    <div class="card border-0 shadow-sm"><div class="card-body p-4"><form><div class="mb-3"><label class="form-label fw-semibold">Product name</label><input class="form-control form-control-lg" value="@(editing ? "Wireless Headphones" : "")" placeholder="Enter product name" /></div><div class="mb-3"><label class="form-label fw-semibold">Description</label><textarea class="form-control" rows="5" placeholder="Describe the product">@(editing ? "Premium sound with active noise cancellation." : "")</textarea></div><div class="row"><div class="col-md-6 mb-3"><label class="form-label fw-semibold">Price</label><div class="input-group input-group-lg"><span class="input-group-text">$</span><input type="number" class="form-control" value="@(editing ? "249.00" : "")" placeholder="0.00" /></div></div><div class="col-md-6 mb-3"><label class="form-label fw-semibold">Stock quantity</label><input type="number" class="form-control form-control-lg" value="@(editing ? "18" : "")" placeholder="0" /></div></div><hr class="my-4" /><div class="d-flex justify-content-end gap-2"><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a><button type="button" class="btn btn-primary">@(editing ? "Save Changes" : "Create Product")</button></div></form></div></div>
</div></div>
