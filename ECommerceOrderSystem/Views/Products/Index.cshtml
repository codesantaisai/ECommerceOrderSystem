@model IReadOnlyList<Product>
@{
    ViewData["Title"] = User.IsInRole("ADMIN") ? "Manage Products" : "Products";
}
<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
        <span class="text-primary fw-semibold small">@(User.IsInRole("ADMIN") ? "ADMIN · INVENTORY" : "PRODUCT CATALOG")</span><h1 class="display-6 fw-bold mb-1">@(User.IsInRole("ADMIN") ? "Manage products" : "Products")</h1><p class="text-muted mb-0">@(User.IsInRole("ADMIN") ? "Review and maintain the store inventory." : "Browse the latest products available in our store.")</p>
    </div>
    @if(User.IsInRole("ADMIN"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Product</a>
    }
</div>
@if(TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">@message<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if(TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@errorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
<form method="get" class="row g-3 mb-4">
    <div class="col-md-9">
        <div class="input-group">
            <span class="input-group-text bg-white">Search</span>
            <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search products..." />
        </div>
    </div>
    <div class="col-md-3 d-grid">
        <button class="btn btn-outline-primary" type="submit">Search products</button>
    </div>
</form>
@if(Model.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <h2 class="h4">No products found</h2>
            <p class="text-muted">@(string.IsNullOrWhiteSpace(ViewBag.Search as string) ? "The catalog is currently empty." : "Try a different search term.")</p>
            @if(User.IsInRole("ADMIN"))
            {
                <a asp-action="Create" class="btn btn-primary">Create the first product</a>
            }
        </div>
    </div>
}
else if(User.IsInRole("ADMIN"))
{
    <partial name="_AdminProductTable" model="Model" />
}
else
{
    <partial name="_CustomerProductCards" model="Model" />
}
