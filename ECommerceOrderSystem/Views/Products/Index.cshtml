@{ ViewData["Title"] = "Products"; }
<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div><span class="text-primary fw-semibold small">PRODUCT CATALOG</span><h1 class="display-6 fw-bold mb-1">Products</h1><p class="text-muted mb-0">Browse the latest products available in our store.</p></div>
    <a asp-action="Create" class="btn btn-primary">+ Add Product</a>
</div>
<div class="row g-3 mb-4"><div class="col-md-8"><div class="input-group"><span class="input-group-text bg-white">⌕</span><input class="form-control" placeholder="Search products..." /></div></div><div class="col-md-4"><select class="form-select"><option>All products</option><option>In stock</option><option>Out of stock</option></select></div></div>
@{ var products = new[] { new { Id="1", Name="Wireless Headphones", Description="Premium sound with active noise cancellation.", Price="249.00", Stock="18 in stock", Color="primary" }, new { Id="2", Name="Mechanical Keyboard", Description="Compact wireless keyboard with tactile switches.", Price="129.50", Stock="7 in stock", Color="success" }, new { Id="3", Name="4K Desk Monitor", Description="27-inch display with USB-C and adjustable stand.", Price="389.99", Stock="Out of stock", Color="warning" }, new { Id="4", Name="Ergonomic Mouse", Description="Precision wireless mouse for comfortable work.", Price="79.00", Stock="32 in stock", Color="info" } }; }
<div class="row g-4">
@foreach (var item in products) {
    <div class="col-md-6 col-xl-3"><div class="card h-100 border-0 shadow-sm"><div class="bg-@item.Color bg-opacity-10 d-flex align-items-center justify-content-center" style="height:180px"><span class="display-2 fw-bold text-@item.Color">@item.Name[0]</span></div><div class="card-body"><div class="d-flex justify-content-between gap-2"><h2 class="h5 fw-bold">@item.Name</h2><strong class="text-nowrap">$@item.Price</strong></div><p class="text-muted small">@item.Description</p><div class="d-flex justify-content-between align-items-center"><span class="badge @(item.Stock == "Out of stock" ? "text-bg-secondary" : "text-bg-success")">@item.Stock</span><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Edit</a></div></div></div></div>
}
</div>
